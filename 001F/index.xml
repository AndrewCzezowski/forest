                    </fr:date>
                    <fr:title text="Algebraic Limit Theorem">Algebraic Limit Theorem</fr:title>
                    <fr:taxon>Theorem</fr:taxon>
                  </fr:frontmatter>
                  <fr:mainmatter>
                    <html:ol><html:li><fr:tex display="inline"><![CDATA[\text {lim}\left (a\right )=ca]]></fr:tex>, for all <fr:tex display="inline"><![CDATA[c\in \mathbb {R}]]></fr:tex></html:li>
    <html:li><fr:tex display="inline"><![CDATA[\text {lim}\left (a\right )=a+b]]></fr:tex></html:li>
    <html:li><fr:tex display="inline"><![CDATA[\text {lim}\left (a\right )=ab]]></fr:tex></html:li>
    <html:li><fr:tex display="inline"><![CDATA[\text {lim}\left (a\right )=a/b]]></fr:tex>, provided <fr:tex display="inline"><![CDATA[b\neq  0]]></fr:tex></html:li></html:ol>
