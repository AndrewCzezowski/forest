                <fr:tree show-metadata="false">
                  <fr:frontmatter>
                    <fr:authors />
                    <fr:date>
                      <fr:year>2026</fr:year>
                      <fr:month>4</fr:month>
                      <fr:day>23</fr:day>
                    </fr:date>
                    <fr:title text="Order Limit Theorem">Order Limit Theorem</fr:title>
                    <fr:taxon>Theorem</fr:taxon>
                  </fr:frontmatter>
                  <fr:mainmatter>
                    <html:ol><html:li>If <fr:tex display="inline"><![CDATA[a_n\geq  0]]></fr:tex> for all <fr:tex display="inline"><![CDATA[n\in \mathbb {N}]]></fr:tex>, then <fr:tex display="inline"><![CDATA[a\geq  0]]></fr:tex></html:li>
    <html:li>If <fr:tex display="inline"><![CDATA[a_n\leq  b_n]]></fr:tex> for all <fr:tex display="inline"><![CDATA[n\in \mathbb {N}]]></fr:tex>, then <fr:tex display="inline"><![CDATA[a\leq  b]]></fr:tex></html:li>
    <html:li>For a <fr:tex display="inline"><![CDATA[c\in \mathbb {R}]]></fr:tex> where <fr:tex display="inline"><![CDATA[c\leq  b_n]]></fr:tex> for all <fr:tex display="inline"><![CDATA[n\in  \mathbb {N}]]></fr:tex>, then <fr:tex display="inline"><![CDATA[c\leq  b]]></fr:tex>. A similar idea holds for when <fr:tex display="inline"><![CDATA[a_n \leq  c]]></fr:tex>.</html:li></html:ol>
                  </fr:mainmatter>
