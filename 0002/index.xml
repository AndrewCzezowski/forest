    <fr:taxon>Definition</fr:taxon>
  </fr:frontmatter>
  <fr:mainmatter>
    <html:p>A binary operation is a mapping of the <fr:link href="/forest/0001/" title="Cartesian Product" uri="https://andrewczezowski.github.io/forest/0001/" display-uri="0001" type="local">cartesian product</fr:link> to some set.</html:p>
    <fr:tex display="block"><![CDATA[A\circledast  B=C]]></fr:tex>
    <html:p>or</html:p>
    <fr:tex display="block"><![CDATA[\circledast :A\times  B\rightarrow  C]]></fr:tex>
  </fr:mainmatter>
